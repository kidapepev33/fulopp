{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "includes/**/*.php": {
      "runtime": "vercel-php@0.7.3"
    },
    "config/**/*.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/pages/index.html"
    },
    {
      "source": "/fulopp/:path*",
      "destination": "/:path*"
    }
  ]
}
