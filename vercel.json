{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/pages/index.html"
    },
    {
      "source": "/includes/functions/:path*",
      "destination": "/api/functions/:path*"
    },
    {
      "source": "/includes/auth/:path*",
      "destination": "/api/auth/:path*"
    },
    {
      "source": "/fulopp/includes/functions/:path*",
      "destination": "/api/functions/:path*"
    },
    {
      "source": "/fulopp/includes/auth/:path*",
      "destination": "/api/auth/:path*"
    },
    {
      "source": "/fulopp/:path*",
      "destination": "/:path*"
    }
  ]
}
